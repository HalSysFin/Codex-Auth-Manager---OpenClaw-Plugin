{
  "id": "auth-manager-lease-telemetry",
  "name": "Codex Auth Manager Plugin",
  "description": "Acquire and manage CAM-backed auth leases, materialize auth, enforce lease-active auth, and post truthful telemetry.",
  "configSchema": {
    "type": "object",
    "additionalProperties": true,
    "properties": {
      "baseUrl": { "type": "string", "description": "CAM broker base URL, e.g. https://your-auth-manager.example.com" },
      "brokerAddress": { "type": "string", "description": "Alias for baseUrl" },
      "internalApiToken": { "type": "string", "description": "CAM internal API key" },
      "machineId": { "type": "string", "description": "Optional custom machine name. Defaults to the host name." },
      "agentId": { "type": "string", "description": "Optional agent name. Sent as openclaw:<agent>." },
      "leaseId": { "type": ["string", "null"] },
      "authFilePath": { "type": "string" },
      "leaseProfileId": { "type": "string" },
      "enforceLeaseAsActiveAuth": { "type": "boolean" },
      "disallowNonLeaseAuth": { "type": "boolean" },
      "purgeNonLeaseProfilesOnStart": { "type": "boolean" },
      "requestedTtlSeconds": { "type": "number" },
      "refreshIntervalMs": { "type": "number" },
      "autoRenew": { "type": "boolean" },
      "autoRotate": { "type": "boolean" },
      "rotationPolicy": { "type": "string" },
      "flushIntervalMs": { "type": "number" },
      "flushEveryRequests": { "type": "number" },
      "releaseLeaseOnShutdown": { "type": "boolean" }
    }
  }
}
